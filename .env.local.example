# ==================== Supabase 配置 ====================
# Supabase 项目 URL（在 Supabase Dashboard → Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase anonymous key（在 Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key（仅服务端使用，不要暴露在前端！
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ==================== DeepSeek API 配置 ====================
# DeepSeek Chat API Key（在 DeepSeek 控制台获取）
DEEPSEEK_API_KEY=your-deepseek-api-key

# ==================== 项目配置 ====================
# 项目名称
NEXT_PUBLIC_PROJECT_NAME=时空星球